{
  "icon-wc": "<style>:host{display:inline-flex;align-items:center;justify-content:center;width:1em;height:1em;vertical-align:-0.125em;line-height:1}:host([size=s]){width:0.75em;height:0.75em}:host([size=l]){width:1.5em;height:1.5em}:host([size=xl]){width:2em;height:2em}svg{width:100%;height:100%;fill:none;stroke:currentColor;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}</style><slot></slot>",
  "audio-player": "<style>:host{display:block;contain:layout style}*,:before,:after{box-sizing:border-box}[part=player]{display:grid;grid-template-columns:auto 1fr auto;align-items:center;gap:0.5rem;padding:0.75rem 1rem;border-radius:0.5rem;background:var(--surface-2,#f3f3f3);color:var(--text-1,#1a1a1a)}button{cursor:pointer;background:none;border:none;padding:0.25rem;color:inherit;display:inline-flex;align-items:center;justify-content:center;border-radius:0.25rem}button:hover{background:var(--surface-3,#e0e0e0)}[part=play]{width:2.5rem;height:2.5rem}[part=play] svg{width:1.25rem;height:1.25rem}[part=timeline]{display:flex;align-items:center;gap:0.5rem;min-width:0}[part=progress]{flex:1;height:4px;border-radius:2px;background:var(--surface-3,#e0e0e0);appearance:none;cursor:pointer}[part=time]{font-size:0.75rem;font-variant-numeric:tabular-nums;white-space:nowrap;color:var(--text-2,#666)}[part=controls]{display:flex;align-items:center;gap:0.25rem}</style><div part=\"player\"><button part=\"play\" aria-label=\"Play\"><svg viewBox=\"0 0 24 24\" fill=\"currentColor\" stroke=\"none\"><polygon points=\"6 3 20 12 6 21\"></polygon></svg></button><div part=\"timeline\"><span part=\"time\">0:00</span><input part=\"progress\" type=\"range\" min=\"0\" max=\"100\" value=\"0\" aria-label=\"Seek\"><span part=\"time\">0:00</span></div><div part=\"controls\"><slot></slot></div></div>",
  "video-player": "<style>:host{display:block;contain:layout style;position:relative;background:#000;border-radius:0.5rem;overflow:hidden;aspect-ratio:16/9}*,:before,:after{box-sizing:border-box}[part=player]{position:relative;width:100%;height:100%;display:flex;flex-direction:column}video,[part=video]{width:100%;height:100%;object-fit:contain}[part=controls]{position:absolute;bottom:0;left:0;right:0;display:grid;grid-template-columns:auto 1fr auto;align-items:center;gap:0.5rem;padding:0.5rem 0.75rem;background:linear-gradient(transparent,rgba(0,0,0,0.7));color:#fff;opacity:0;transition:opacity 0.3s}:host(:hover) [part=controls],:host([data-controls-visible]) [part=controls]{opacity:1}button{cursor:pointer;background:none;border:none;padding:0.25rem;color:#fff;display:inline-flex;align-items:center;justify-content:center}[part=play] svg{width:1.5rem;height:1.5rem}[part=progress]{flex:1;height:4px;border-radius:2px;background:rgba(255,255,255,0.3);appearance:none;cursor:pointer}[part=time]{font-size:0.75rem;font-variant-numeric:tabular-nums}</style><div part=\"player\"><div part=\"video\"><slot></slot></div><div part=\"controls\"><button part=\"play\" aria-label=\"Play\"><svg viewBox=\"0 0 24 24\" fill=\"currentColor\" stroke=\"none\"><polygon points=\"6 3 20 12 6 21\"></polygon></svg></button><div style=\"display:flex;align-items:center;gap:0.5rem;flex:1\"><span part=\"time\">0:00</span><input part=\"progress\" type=\"range\" min=\"0\" max=\"100\" value=\"0\" aria-label=\"Seek\"><span part=\"time\">0:00</span></div><div part=\"controls-right\"></div></div></div>",
  "geo-map": "<style>:host{display:block;contain:layout style;position:relative;border-radius:0.5rem;overflow:hidden;aspect-ratio:16/9;background:var(--surface-2,#e8e8e8)}*,:before,:after{box-sizing:border-box}[part=container]{position:relative;width:100%;height:100%;overflow:hidden;touch-action:none}[part=tiles]{position:absolute;inset:0}[part=overlay]{position:absolute;inset:0;pointer-events:none;display:flex;align-items:center;justify-content:center}[part=caption]{position:absolute;bottom:0;left:0;right:0;padding:0.5rem 0.75rem;background:rgba(0,0,0,0.6);color:#fff;font-size:0.85rem}[part=attribution]{position:absolute;bottom:0;right:0;padding:0.125rem 0.375rem;font-size:0.625rem;background:rgba(255,255,255,0.7);color:#333}[part=attribution] a{color:inherit}</style><div part=\"container\"><div part=\"tiles\"></div><div part=\"overlay\"></div></div><div part=\"attribution\">&copy; <a href=\"https://www.openstreetmap.org/copyright\">OpenStreetMap</a></div>",
  "audio-visualizer": "<style>:host{display:block;contain:layout style}canvas{display:block;width:100%;height:100%;border-radius:0.25rem}</style><canvas aria-hidden=\"true\"></canvas>"
