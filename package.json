{
  "name": "cook",
  "siteName": "cook",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "node patches/jsdom-fetch-fix.js",
    "build": "node scripts/build.js",
    "dev": "NODE_ENV=development npm run build && node scripts/dev.js",
    "dev:prod": "NODE_ENV=production npm run build && http-server ./dist -p $npm_package_config_devPort",
    "test": "node --test test/*.test.js",
    "test:watch": "node --test --watch test/*.test.js",
    "reset": "rm -rf node_modules",
    "reset:install": "npm run reset && npm install",
    "update:check": "ncu",
    "update:fix": "ncu -u"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "config": {
    "devPort": 3000
  },
  "dependencies": {
    "browser-sync": "^3.0.4",
    "chalk": "^5.4.1",
    "clean-css": "^5.3.3",
    "cli-cursor": "^5.0.0",
    "cli-spinners": "^3.3.0",
    "fs-extra": "^11.3.2",
    "gray-matter": "^4.0.3",
    "html-minifier-terser": "^7.2.0",
    "http-server": "^14.1.1",
    "jsdom": "^27.3.0",
    "lodash.clonedeep": "^4.5.0",
    "lodash.merge": "^4.6.2",
    "marked": "^17.0.1",
    "npm-check-updates": "^19.2.0",
    "rimraf": "^6.1.2",
    "sharp": "^0.34.5",
    "terser": "^5.44.1"
  }
}
